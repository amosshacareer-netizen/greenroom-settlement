# Anthropic API key for the LLM deal parser (lib/parseDealLLM.ts).
# When unset, the app falls back to the regex parser (lib/parseDeal.ts)
# so the demo runs offline without credentials.
#
# Production: get a key at https://console.anthropic.com, set it here,
# and import parseDealHybrid from lib/parseDealLLM in app/shows/[id]/settle/page.tsx.
ANTHROPIC_API_KEY=
